; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=4

[application]

config/name="Achtung Die Spurve"
run/main_scene="res://Scenes/Lobby.tscn"
config/icon="res://icon.png"
config/main_scene="res://Scenes/Lobby.tscn"

[autoload]

GameData="*res://Scripts/GameData.cs"

[display]

window/size/width=1324

[global]

theme=false

[gui]

common/drop_mouse_on_gui_input_disabled=true
theme/custom_font="res://Assets/Fonts/Baloo2-VariableFont_wght.ttf"

[mono]

project/assembly_name="Achtung Die Spurve"

[physics]

common/enable_pause_aware_picking=true

[rendering]

environment/default_environment="res://default_env.tres"
batching/parameters/item_buffer_size=4096

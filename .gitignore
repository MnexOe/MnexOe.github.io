# Godot 4+ specific ignores (Safe to keep, but Godot 3 doesn't use this)
.godot/
.nomedia

# Godot 3-specific cache (CRUCIAL ADDITION)
.import/
.mono/          # (Keep this if you are using the C#/.NET version of Godot 3)

# Build and export configs
export.cfg
export_presets.cfg     # (Make sure this matches your project; Godot 3 often uses export_presets.cfg)
export_credentials.cfg
*.tmp

# Imported translations (automatically generated from CSV files)
*.translation

# Mono-specific ignores
data_*/
mono_crash.*.json
